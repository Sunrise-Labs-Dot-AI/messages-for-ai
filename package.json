{
  "name": "imessage-mcp",
  "version": "0.1.0",
  "description": "Local MCP server for macOS iMessages: read-only chat.db queries, draft staging with thread-context snapshots, AppleScript send. Designed for Claude Desktop / Claude Code / Codex CLI.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "imessage",
    "messages",
    "macos",
    "apple",
    "chat.db",
    "claude",
    "stdio"
  ],
  "license": "MIT",
  "author": "imessage-mcp contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sunrise-Labs-Dot-AI/imessage-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Sunrise-Labs-Dot-AI/imessage-mcp/issues"
  },
  "homepage": "https://github.com/Sunrise-Labs-Dot-AI/imessage-mcp#readme",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --compile --outfile bin/imessage-mcp",
    "install:bin": "bash scripts/dev-install.sh",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "typescript": "^5.6.0"
  }
}
