  "_meta": {
    "title": "Texting Wrapped — Age-Band Estimation Rubric (machine-readable config)",
    "description": "Probabilistic, NOT deterministic. Each feature contributes weighted points toward an age band. Sum points per band, normalize, pick highest. See scoring_logic.",
