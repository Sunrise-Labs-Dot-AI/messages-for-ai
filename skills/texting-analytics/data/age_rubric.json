  },

  "scoring_logic": {
    "step_1": "For each observed feature, add its band points (multiplied by weight) to each band's running total.",
    "step_2": "Normalize each band total by the sum of weights of all observed features.",
    "step_3": "The band with the highest normalized score is the best-fit estimate.",
    "step_4_confidence": "If top band >= 2x second place: report 'likely [band]'. If top two within 20%: report a two-band range (e.g. 'Millennial/Gen X').",
    "weight_values": {"high": 3, "medium": 2, "low": 1}
  },

